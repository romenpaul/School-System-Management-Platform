@model IEnumerable<Routine>

<h2>Routine List</h2>

<a asp-action="Create"
       class="btn btn-primary mb-3">

    Upload Routine

</a>

<table class="table table-bordered">

    <thead>

        <tr>
            <th>Title</th>
            <th>Type</th>
            <th>PDF</th>
            <th>Delete</th>
        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Title</td>

                <td>@item.Type</td>

                <td>

                    <a href="@item.FilePath"
                           target="_blank"
                           class="btn btn-success">

                        View PDF

                    </a>

                </td>

                <td>

                    <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger">

                        Delete

                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>