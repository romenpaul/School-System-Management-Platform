@{
    ViewData["Title"] = "Home";
}

@if (!User.Identity.IsAuthenticated)
{
    <!-- PREMIUM TOP-NOTCH GUEST HOME -->
    <div class="guest-hero-bg">
        <div style="max-width: 1200px; margin: 0 auto; padding: 6rem 2rem; display: flex; flex-direction: column; align-items: center; justify-content: center;">
            
            <!-- HERO TEXT -->
            <div class="text-center mb-5 animate-up">
                <div style="display: inline-block; padding: 0.5rem 1.5rem; background: rgba(79, 70, 229, 0.1); color: var(--primary); border-radius: 2rem; font-weight: 700; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem;">
                    Premium Educational Solution
                </div>
                <h1 style="font-size: 5rem; font-weight: 800; letter-spacing: -0.04em; line-height: 1.1; margin-bottom: 2rem; color: var(--text-main);">
                    School Management<br/>
                    <span style="background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">System</span>
                </h1>
                
                <!-- MAIN ACTIONS -->
                <div class="d-flex flex-wrap justify-content-center gap-3 mt-4">
                    <a asp-controller="Account" asp-action="Login" class="btn-primary-premium">
                        <i class="fas fa-sign-in-alt"></i>
                        Login to Portal
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn-secondary-premium">
                        <i class="fas fa-user-plus"></i>
                        Register School
                    </a>
                </div>
            </div>

            <!-- STATS SECTION -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem; width: 100%; max-width: 1000px; margin-top: 4rem;" class="animate-up">
                
                <!-- TOTAL USERS -->
                <div class="premium-card">
                    <div class="d-flex align-items-center gap-4">
                        <div style="width: 80px; height: 80px; background: rgba(79, 70, 229, 0.08); color: var(--primary); border-radius: 1.25rem; display: flex; align-items: center; justify-content: center; font-size: 2rem;">
                            <i class="fas fa-users-viewfinder"></i>
                        </div>
                        <div>
                            <div class="stat-label">System Users</div>
                            <div class="stat-value">@ViewBag.TotalUsers</div>
                        </div>
                    </div>
                    <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color); color: var(--text-muted); font-size: 0.875rem;">
                        <i class="fas fa-shield-halved me-2 text-primary"></i> Verified administrative accounts
                    </div>
                </div>

                <!-- TOTAL STUDENTS -->
                <div class="premium-card">
                    <div class="d-flex align-items-center gap-4">
                        <div style="width: 80px; height: 80px; background: rgba(6, 182, 212, 0.08); color: var(--accent); border-radius: 1.25rem; display: flex; align-items: center; justify-content: center; font-size: 2rem;">
                            <i class="fas fa-graduation-cap"></i>
                        </div>
                        <div>
                            <div class="stat-label">Total Students</div>
                            <div class="stat-value">@ViewBag.TotalStudents</div>
                        </div>
                    </div>
                    <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color); color: var(--text-muted); font-size: 0.875rem;">
                        <i class="fas fa-check-double me-2 text-accent"></i> Currently enrolled scholars
                    </div>
                </div>

            </div>
        </div>
    </div>
}
else
{
    <!-- PREMIUM ADMIN DASHBOARD -->
    <div class="row g-4 animate-up">
        <div class="col-md-4">
            <div class="premium-card" style="border-left: 4px solid var(--primary);">
                <div class="stat-label">Active Students</div>
                <div class="stat-value">@ViewBag.TotalStudents</div>
                <div class="mt-2 text-success small"><i class="fas fa-arrow-up"></i> +5% from last month</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="premium-card" style="border-left: 4px solid var(--accent);">
                <div class="stat-label">Total Staff</div>
                <div class="stat-value">@ViewBag.TotalUsers</div>
                <div class="mt-2 text-muted small"><i class="fas fa-user-check"></i> System administrators</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="premium-card" style="border-left: 4px solid #10b981;">
                <div class="stat-label">Server Health</div>
                <div class="stat-value text-success" style="font-size: 1.5rem;">Operational</div>
                <div class="mt-2 text-muted small"><i class="fas fa-clock"></i> Up-time: 99.9%</div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="premium-card" style="min-height: 400px;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold m-0">Management Overview</h5>
                    <div class="badge bg-light text-primary p-2">Session: 2026-27</div>
                </div>
                <div class="p-5 text-center border rounded-4 bg-light" style="border-style: dashed !important;">
                    <i class="fas fa-chart-line fa-4x mb-3 text-muted opacity-25"></i>
                    <h6 class="text-muted fw-bold">Live Data Stream Ready</h6>
                    <p class="text-muted small">Academic performance and metrics will populate here as data is recorded.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="premium-card" style="min-height: 400px;">
                <h5 class="fw-bold mb-4">Core Actions</h5>
                <div class="d-grid gap-3">
                    <a asp-controller="Student" asp-action="Index" class="btn btn-light text-start p-3 border rounded-3 shadow-sm">
                        <div class="d-flex align-items-center gap-3">
                            <div class="p-2 bg-primary text-white rounded-2"><i class="fas fa-user-graduate"></i></div>
                            <div>
                                <div class="fw-bold">Student Directory</div>
                                <div class="small text-muted">Manage enrollments</div>
                            </div>
                        </div>
                    </a>
                    <a asp-controller="Teacher" asp-action="Index" class="btn btn-light text-start p-3 border rounded-3 shadow-sm">
                        <div class="d-flex align-items-center gap-3">
                            <div class="p-2 bg-info text-white rounded-2"><i class="fas fa-chalkboard-teacher"></i></div>
                            <div>
                                <div class="fw-bold">Teacher Records</div>
                                <div class="small text-muted">Faculty management</div>
                            </div>
                        </div>
                    </a>
                    <a asp-controller="Routine" asp-action="Index" class="btn btn-light text-start p-3 border rounded-3 shadow-sm">
                        <div class="d-flex align-items-center gap-3">
                            <div class="p-2 bg-success text-white rounded-2"><i class="fas fa-calendar-days"></i></div>
                            <div>
                                <div class="fw-bold">Academic Routine</div>
                                <div class="small text-muted">Schedules & Timings</div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
}