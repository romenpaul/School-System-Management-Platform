@model User
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="text-center mb-4">Register</h2>

        <form asp-action="Register" method="post" class="card p-4 shadow-sm">
            <div class="form-group mb-3">
                <label asp-for="UserName">Username</label>
                <input asp-for="UserName" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label asp-for="PasswordHash">Password</label>
                <input asp-for="PasswordHash" type="password" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Address">Address</label>
                <input asp-for="Address" class="form-control" />
            </div>
            <button type="submit" class="btn btn-success w-100">Register</button>
            <div class="text-center mt-3">
                <a asp-action="Login">Already have an account? Login</a>
            </div>
        </form>
    </div>
</div>
