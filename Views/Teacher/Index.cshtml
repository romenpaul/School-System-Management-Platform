@model IEnumerable<Teacher>

<h2>Teacher List</h2>

<a asp-action="Create"
       class="btn btn-primary mb-3">
    Create Teacher
</a>

<table class="table table-bordered table-striped">

    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Department</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Name</td>

                <td>@item.Email</td>

                <td>
                    @item.Department?.DepartmentName
                </td>

                <td>

                    <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                        Delete
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>

<!-- PAGINATION -->

<div class="mt-3">

    @for (int i = 1; i <= ViewBag.TotalPages; i++)
    {
        <a asp-action="Index"
               asp-route-page="@i"
               class="btn btn-sm
            @(ViewBag.CurrentPage == i
                       ? "btn-primary"
                       : "btn-outline-primary")">

            @i

        </a>
    }

</div>